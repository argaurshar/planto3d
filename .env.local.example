# Copy this file to `.env.local` and fill in your key.
#
# kie.ai API key with access to the Nano Banana 2 model (`nano-banana-2`).
# Get / manage your key at https://kie.ai/api-key
#
# This key is used ONLY server-side (in app/api/* route handlers and
# lib/kie.ts); it is never exposed to the browser.
KIE_API_KEY=

# Optional overrides:
# KIE_IMAGE_MODEL=nano-banana-2
# KIE_IMAGE_RESOLUTION=1K        # one of: 1K, 2K, 4K
