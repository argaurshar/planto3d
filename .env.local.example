# Copy this file to `.env.local` and fill in your key.
#
# Google Gemini API key with access to Nano Banana Pro
# (the Gemini 3 Pro Image model, id: gemini-3-pro-image-preview).
# Get a key at https://aistudio.google.com/apikey
#
# This key is used ONLY server-side (in app/api/* route handlers); it is
# never exposed to the browser.
GEMINI_API_KEY=

# Optional override of the image model id.
# GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview
